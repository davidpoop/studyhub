# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/studyhub"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# Get from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="studyhub-uploads"
# Optional: custom domain for public access to R2 objects
R2_PUBLIC_DOMAIN=""

# ─── Mux ─────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.mux.com > Settings > API Access Tokens
MUX_TOKEN_ID="your-mux-token-id"
MUX_TOKEN_SECRET="your-mux-token-secret"
# Get from: Mux Dashboard > Settings > Webhooks
MUX_WEBHOOK_SECRET="your-mux-webhook-secret"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Create a subscription price in Stripe Dashboard and paste ID here
STRIPE_PRICE_ID="price_..."
# Get from: Stripe Dashboard > Developers > Webhooks (after creating webhook)
STRIPE_WEBHOOK_SECRET="whsec_..."
